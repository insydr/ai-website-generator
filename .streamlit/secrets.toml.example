# Streamlit Secrets Configuration
# ================================
# 
# This file stores sensitive configuration like API keys.
# 
# IMPORTANT: 
# - Rename this file to 'secrets.toml' to use it
# - NEVER commit your actual API keys to version control
# - Add 'secrets.toml' to your .gitignore file
#
# Usage:
# 1. Copy this file and rename to 'secrets.toml'
# 2. Replace the placeholder with your actual API key
# 3. The app will automatically load the key

# OpenRouter API Key
# Get your key at: https://openrouter.ai/keys
# Format: sk-or-v1-xxxxxxxxxxxxx
openrouter_api_key = "YOUR_OPENROUTER_API_KEY_HERE"

# Optional: Additional configuration
# [app]
# title = "AI Website Generator"
# debug = false
